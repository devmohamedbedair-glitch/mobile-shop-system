@model MobileShop.Models.Product

<h2>Edit Product</h2>

<form method="post">
    <input type="hidden" name="Id" value="@Model.Id" />

    <div>
        <label>Name</label>
        <input type="text" name="Name" value="@Model.Name" class="form-control" />
    </div>

    <div>
        <label>Price</label>
        <input type="number" name="Price" value="@Model.Price" class="form-control" />
    </div>

    <div>
        <label>Quantity</label>
        <input type="number" name="Quantity" value="@Model.Quantity" class="form-control" />
    </div>

    <div>
        <label>Category</label>
        <input type="text" name="Category" value="@Model.Category" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">Update</button>
</form>